# ============================================================================
# TaskMaster on-prem configuration
# Copy to `.env` and fill in. NEVER commit the populated `.env` file.
# ============================================================================

# --- Public URL --------------------------------------------------------------
DOMAIN=taskmaster.example.com
PROTOCOL=https
PUBLIC_URL=${PROTOCOL}://${DOMAIN}

# --- Postgres ----------------------------------------------------------------
# A1 (single VM): leave DB_EMBEDDED=true — the bundled `db` container runs.
# A2 / B / C (Postgres on its own VM): set DB_EMBEDDED=false and point
# POSTGRES_HOST at the DB VM's private IP / DNS name.
DB_EMBEDDED=true
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# --- Auth / JWT --------------------------------------------------------------
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-64-byte-hex-string
JWT_EXPIRY=3600
# Both are derived from JWT_SECRET on first install if left blank.
ANON_KEY=
SERVICE_ROLE_KEY=

# --- License -----------------------------------------------------------------
# Issued by your TaskMaster account team. JWT signed with the platform private
# key; verified at install/upgrade and on each call to set_license_status.
LICENSE_KEY=

# --- AI provider (default: local Ollama) -------------------------------------
AI_PROVIDER=ollama
AI_BASE_URL=http://ollama:11434
AI_DEFAULT_MODEL=llama3.1:8b
# If using OpenAI / Azure / Anthropic instead, set:
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...

# --- SMTP --------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=
SMTP_FROM="TaskMaster <notifications@example.com>"
SMTP_TLS=true

# --- Storage -----------------------------------------------------------------
# Local volume by default; switch to S3-compatible object storage once you
# have multiple app hosts (Topology B+) or want simpler backup / DR.
# "S3" here = AWS S3, on-prem MinIO, Ceph RGW, Wasabi, etc. — any S3 API.
STORAGE_DRIVER=file
STORAGE_PATH=/var/lib/taskmaster/storage
# S3-compatible alternative:
# STORAGE_DRIVER=s3
# STORAGE_S3_BUCKET=taskmaster-uploads
# STORAGE_S3_REGION=eu-west-1
# STORAGE_S3_ENDPOINT=                          # omit for AWS S3; set for MinIO/Ceph
# STORAGE_S3_ACCESS_KEY=
# STORAGE_S3_SECRET_KEY=

# --- Telemetry (opt-in) ------------------------------------------------------
# When true, the edge runtime polls updates.taskmaster.app and may submit
# anonymized health metrics. Off by default for air-gapped installs.
ALLOW_OUTBOUND_TELEMETRY=false
UPDATE_CHANNEL=stable

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=info
LOG_RETENTION_DAYS=30
