# ============================================================================
# TaskMaster on-prem configuration
# Copy to `.env` and fill in. NEVER commit the populated `.env` file.
# ============================================================================

# --- Public URL --------------------------------------------------------------
DOMAIN=taskmaster.example.com
PROTOCOL=https
PUBLIC_URL=${PROTOCOL}://${DOMAIN}

# --- Postgres ----------------------------------------------------------------
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# --- Auth / JWT --------------------------------------------------------------
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-64-byte-hex-string
JWT_EXPIRY=3600
# Both are derived from JWT_SECRET on first install if left blank.
ANON_KEY=
SERVICE_ROLE_KEY=

# --- License -----------------------------------------------------------------
# Issued by your TaskMaster account team. JWT signed with the platform private
# key; verified at install/upgrade and on each call to set_license_status.
LICENSE_KEY=

# --- AI provider (default: local Ollama) -------------------------------------
AI_PROVIDER=ollama
AI_BASE_URL=http://ollama:11434
AI_DEFAULT_MODEL=llama3.1:8b
# If using OpenAI / Azure / Anthropic instead, set:
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...

# --- SMTP --------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=
SMTP_FROM="TaskMaster <notifications@example.com>"
SMTP_TLS=true

# --- Storage -----------------------------------------------------------------
# Local volume by default; can be swapped for S3-compatible object storage.
# See onprem/docs/object-storage.md for the decision matrix and IAM policy.
STORAGE_DRIVER=file
STORAGE_PATH=/var/lib/taskmaster/storage

# S3 / MinIO alternative (REQUIRED for multi-host app tier):
# STORAGE_DRIVER=s3
# S3_BUCKET=taskmaster-uploads
# S3_REGION=us-east-1
# S3_ENDPOINT=http://minio:9000     # blank for AWS S3
# S3_FORCE_PATH_STYLE=true          # true for MinIO/R2/Ceph; false for AWS
# S3_ACCESS_KEY=                    # 20+ chars alphanumeric
# S3_SECRET_KEY=                    # 40+ chars

# --- MinIO (only if running docker-compose.minio.yml) ------------------------
# Admin credentials for the MinIO console + bootstrap job.
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=                # openssl rand -hex 32
# MINIO_SERVER_URL=https://minio.taskmaster.example.com
# MINIO_CONSOLE_URL=https://minio-console.taskmaster.example.com

# --- Telemetry (opt-in) ------------------------------------------------------
# When true, the edge runtime polls updates.taskmaster.app and may submit
# anonymized health metrics. Off by default for air-gapped installs.
ALLOW_OUTBOUND_TELEMETRY=false
UPDATE_CHANNEL=stable

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=info
LOG_RETENTION_DAYS=30
